# Neo4j Connection (REQUIRED)
# These must be set - no defaults in code or YAML
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# LLM API Keys (REQUIRED - choose one based on provider in app-config/config.yml)
# All LLM configuration (provider, model, temperature, Azure settings) is in app-config/config.yml

# Option 1: OpenAI (if provider: openai in config.yml)
LLM_API_KEY=your-openai-api-key

# Option 2: Azure OpenAI (if provider: azure_openai in config.yml)
# AZURE_OPENAI_API_KEY=your-azure-api-key
